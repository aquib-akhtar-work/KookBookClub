	return s.sendEmail(toEmail, subject, htmlBody, textBody)
}

func (s *Server) sendPasswordChangeCodeEmail(
	toEmail,
	username,
	displayName,
	code,
	expiresAt string,
) error {
	name := strings.TrimSpace(displayName)
	if name == "" {
		name = strings.TrimSpace(username)
	}
